# Optional internal LLM endpoint. Leave blank to use local retrieval-only answers.
# The endpoint should be OpenAI-compatible and accept POST /chat/completions.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=internal-llm
LLM_TIMEOUT=120

# Optional manual navigator preferences.
# Values are manual IDs derived from local raw/manuals PDF filenames or index directories.
# Keep deployment-specific material names in .env; do not commit them.
EDA_DEFAULT_MANUAL_ID=
EDA_QUICK_MANUAL_IDS=
